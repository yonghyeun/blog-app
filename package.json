{
  "name": "blog-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest run --project=unit",
    "test:storybook": "vitest run --project=storybook",
    "test:e2e": "npm run test:e2e:default && npm run test:e2e:empty && npm run test:e2e:missing-env",
    "test:e2e:default": "BLOG_POST_REPO_PATH=tests/e2e/fixtures/blog-post-default BLOG_POST_ASSET_URL_PREFIX=/post-assets playwright test tests/e2e/renderer-default.spec.ts",
    "test:e2e:empty": "BLOG_POST_REPO_PATH=tests/e2e/fixtures/blog-post-empty BLOG_POST_ASSET_URL_PREFIX=/post-assets playwright test tests/e2e/renderer-empty.spec.ts",
    "test:e2e:missing-env": "playwright test tests/e2e/renderer-missing-env.spec.ts",
    "hooks:install": "git config core.hooksPath .githooks",
    "test:githooks": "bash .githooks/pre-commit.test.sh",
    "validate:skills": "node scripts/validate-skills.mjs",
    "test:skills-validator": "node --test scripts/validate-skills.test.mjs",
    "typecheck": "tsc --noEmit",
    "worktree:add": ".codex/skills/task-intake/scripts/worktree-add.sh",
    "worktree:remove": ".codex/skills/task-close/scripts/worktree-remove.sh",
    "worktree:workspace": "node .codex/skills/task-close/scripts/update-vscode-workspace.mjs"
  },
  "dependencies": {
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/nextjs-vite": "^10.4.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
