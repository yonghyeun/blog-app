# Local sibling checkout for development. Example only.
BLOG_POST_REPO_PATH=

# Public URL prefix used for resolved post attachment images.
BLOG_POST_ASSET_URL_PREFIX=

# Future build/server checkout source. Do not include credentials in this value.
BLOG_POST_REPO_URL=

# Local path to a read-only deploy key. Never expose this to client code.
BLOG_POST_DEPLOY_KEY_PATH=

# Local Figma design file key for MCP design work. Do not commit concrete values.
FIGMA_VERTICAL_SLICE_V1_FILE_KEY=

# Local Figma REST token. Comment reads require file_comments:read.
# Do not commit concrete values.
FIGMA_ACCESS_TOKEN=
